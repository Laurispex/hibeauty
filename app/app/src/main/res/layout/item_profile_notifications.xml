<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="86dp"
    android:background="@drawable/bg_card_white"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="18dp">

    <TextView android:layout_width="50dp" android:layout_height="50dp" android:background="@drawable/bg_circle_pink" android:gravity="center" android:text="🔔" android:textSize="23sp" />
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_weight="1" android:orientation="vertical">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Notificaciones" android:textColor="@color/hib_ink" android:textSize="18sp" android:textStyle="bold" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pedidos, ofertas y rutina" android:textColor="@color/hib_muted" android:textSize="14sp" android:textStyle="bold" />
    </LinearLayout>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textColor="@color/hib_muted" android:textSize="34sp" />
</LinearLayout>
