<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hib_page"
    android:paddingStart="32dp"
    android:paddingEnd="32dp"
    android:paddingBottom="28dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="28dp" android:text="Rutina 📅" android:textColor="@color/hib_ink" android:textSize="32sp" android:textStyle="bold" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Tu plan beauty de hoy" android:textColor="@color/hib_muted" android:textSize="16sp" android:textStyle="bold" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="136dp" android:layout_marginTop="24dp" android:background="@drawable/bg_promo" android:orientation="vertical" android:padding="24dp">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="🌞 Rutina de mañana" android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Tienes 2 pasos completados de 4." android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold" />
            <TextView android:layout_width="120dp" android:layout_height="42dp" android:layout_marginTop="16dp" android:background="@drawable/bg_button_white" android:gravity="center" android:text="Continuar" android:textColor="#9B00FF" android:textSize="15sp" android:textStyle="bold" />
        </LinearLayout>

        <include android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="22dp" layout="@layout/item_routine_clean" />
        <include android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" layout="@layout/item_routine_serum" />
        <include android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" layout="@layout/item_routine_hydrate" />
        <include android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" layout="@layout/item_routine_sunscreen" />
    </LinearLayout>
</ScrollView>
