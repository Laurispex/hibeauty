<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hib_page"
    android:paddingStart="32dp"
    android:paddingEnd="32dp"
    android:paddingBottom="28dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="28dp" android:text="Descubre ✨" android:textColor="@color/hib_ink" android:textSize="32sp" android:textStyle="bold" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Tendencias, rituales y favoritos para ti" android:textColor="@color/hib_muted" android:textSize="16sp" android:textStyle="bold" />

        <TextView android:layout_width="match_parent" android:layout_height="64dp" android:layout_marginTop="24dp" android:background="@drawable/bg_search" android:gravity="center_vertical" android:paddingStart="20dp" android:text="🔎  Buscar serum, lipstick, rutina..." android:textColor="@color/hib_muted" android:textSize="16sp" android:textStyle="bold" />

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="30dp" android:text="Colecciones HiBeauty 🌸" android:textColor="@color/hib_ink" android:textSize="24sp" android:textStyle="bold" />

        <include android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="18dp" layout="@layout/item_discover_glow" />
        <include android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="18dp" layout="@layout/item_discover_makeup" />
    </LinearLayout>
</ScrollView>
