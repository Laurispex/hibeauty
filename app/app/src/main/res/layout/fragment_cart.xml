            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:text="Total                                          $79.000" android:textColor="@color/hib_hot_pink" android:textSize="19sp" android:textStyle="bold" />
        </LinearLayout>

        <TextView android:layout_width="match_parent" android:layout_height="58dp" android:layout_marginTop="22dp" android:background="@drawable/bg_button_pink" android:gravity="center" android:text="Finalizar compra" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
