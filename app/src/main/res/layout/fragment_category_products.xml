<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hib_page"
    android:orientation="vertical">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_soft_circle"
            android:padding="16dp"
            android:src="@drawable/ic_back"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Regresar" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/categoryTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Categoría"
                android:textColor="@color/hib_ink"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black" />

            <TextView
                android:id="@+id/categoryCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="0 productos"
                android:textColor="@color/hib_muted"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ImageView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_soft_circle"
            android:padding="16dp"
            android:src="@drawable/ic_filter"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Filtrar" />
    </LinearLayout>

    <!-- TABS -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <TextView
                android:id="@+id/tabAll"
                android:layout_width="120dp"
                android:layout_height="54dp"
                android:background="@drawable/bg_button_pink"
                android:gravity="center"
                android:text="Todo"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tabFeatured"
                android:layout_width="170dp"
                android:layout_height="54dp"
                android:layout_marginStart="14dp"
                android:background="@drawable/bg_tab_outline"
                android:gravity="center"
                android:text="Bestsellers"
                android:textColor="@color/hib_ink"
                android:textSize="16sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tabNew"
                android:layout_width="140dp"
                android:layout_height="54dp"
                android:layout_marginStart="14dp"
                android:background="@drawable/bg_tab_outline"
                android:gravity="center"
                android:text="Nuevos"
                android:textColor="@color/hib_ink"
                android:textSize="16sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tabOffers"
                android:layout_width="140dp"
                android:layout_height="54dp"
                android:layout_marginStart="14dp"
                android:background="@drawable/bg_tab_outline"
                android:gravity="center"
                android:text="Ofertas"
                android:textColor="@color/hib_ink"
                android:textSize="16sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- BANNER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/bg_banner_gradient"
        android:elevation="6dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:id="@+id/bannerIcon"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_flower"
            app:tint="#FFFFFF"
            android:contentDescription="Icono de categoría" />

        <TextView
            android:id="@+id/bannerTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Skincare para ti"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black" />

        <TextView
            android:id="@+id/bannerSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Productos seleccionados con amor para tu piel"
            android:textAlignment="center"
            android:textColor="#FFFFFF"
            android:textSize="15sp" />
    </LinearLayout>

    <!-- PRODUCTS HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <TextView
            android:id="@+id/productsCountText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 productos"
            android:textColor="@color/hib_ink"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ordenar por ▼"
            android:textColor="@color/hib_hot_pink"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- PRODUCTS -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/categoryRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="12dp"
        tools:listitem="@layout/item_user_product" />

</LinearLayout>