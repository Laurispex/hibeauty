<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hib_page"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="34dp">

    <!-- ICON -->

    <TextView
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:background="@drawable/bg_circle_pink"
        android:gravity="center"
        android:text="💖"
        android:textSize="52sp" />

    <!-- TITLE -->

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:text="BeautyLover Access ✨"
        android:textColor="@color/hib_ink"
        android:textSize="30sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-black" />

    <!-- MESSAGE -->

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center"
        android:text="Crea tu cuenta para guardar rutinas, seguir tus pedidos, desbloquear beneficios y vivir la experiencia HiBeauty 💕"
        android:textColor="@color/hib_muted"
        android:textSize="17sp"
        android:textStyle="bold" />

    <!-- BENEFITS -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="34dp"
        android:background="@drawable/bg_card_large"
        android:elevation="3dp"
        android:orientation="vertical"
        android:padding="22dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✨ Guardar rutinas"
            android:textColor="@color/hib_ink"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="🛍 Seguir pedidos"
            android:textColor="@color/hib_ink"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="💖 Acumular puntos"
            android:textColor="@color/hib_ink"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="🎁 Desbloquear descuentos"
            android:textColor="@color/hib_ink"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- BUTTON -->

    <TextView
        android:id="@+id/btnOpenLogin"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:layout_marginTop="36dp"
        android:background="@drawable/bg_button_pink"
        android:gravity="center"
        android:text="✨ Crear cuenta"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold" />

</LinearLayout>