<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="112dp"
    android:background="@drawable/bg_card_white"
    android:elevation="5dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="18dp">

    <ImageView
        android:layout_width="74dp"
        android:layout_height="74dp"
        android:background="@drawable/bg_product_image"
        android:padding="18dp"
        android:src="@drawable/ic_nav_sparkle"
        android:tint="@color/hib_violet"
        android:contentDescription="Mascarilla" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mascarilla de Colágeno"
            android:textColor="@color/hib_ink"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1 unidad - hidratación"
            android:textColor="@color/hib_muted"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="$28.000"
            android:textColor="@color/hib_hot_pink"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ImageView
        android:id="@+id/btnRemoveCartItem"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:padding="8dp"
        android:src="@drawable/ic_trash"
        android:tint="@color/hib_pink"
        android:contentDescription="Eliminar" />
</LinearLayout>
