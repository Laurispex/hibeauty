<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:background="@drawable/bg_card_white"
    android:elevation="4dp"
    android:orientation="vertical"
    android:padding="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/orderTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Pedido #123456"
            android:textColor="@color/hib_ink"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/orderStatus"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/bg_badge"
            android:gravity="center"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:text="Pendiente"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/orderProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="1 de 4 - Pedido recibido"
        android:textColor="@color/hib_pink"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/orderTimeline"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_status_track"
        android:gravity="center"
        android:padding="14dp"
        android:text="● Pedido  ○ Preparando  ○ En camino  ○ Entregado"
        android:textColor="@color/hib_ink"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/orderItems"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="1 x Serum (50ml)"
        android:textColor="@color/hib_muted"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/orderTotal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Total: $0"
        android:textColor="@color/hib_ink"
        android:textSize="16sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/riderInfoContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="#FFF5F7"
        android:orientation="vertical"
        android:padding="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/orderRiderText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏍️ Repartidor: Cargando..."
            android:textColor="@color/hib_ink"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/btnNextOrderStatus"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_button_pink"
        android:gravity="center"
        android:text="Marcar como Preparando"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold" />
</LinearLayout>
