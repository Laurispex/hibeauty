<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:cardPreventCornerOverlap="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- TOP BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/orderIdText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="#BT-E83921"
                android:textColor="@color/hib_ink"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/payoutText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pago: $8.000"
                android:textColor="@color/hib_hot_pink"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="10dp"
            android:background="#FFF0F2" />

        <!-- DETAILS -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tienda (Recogida):"
            android:textColor="#888888"
            android:textSize="11sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="HiBeauty — Av. Carrera 15 # 82-24, Bogotá"
            android:textColor="@color/hib_ink"
            android:textSize="13sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Entrega a (Destino):"
            android:textColor="#888888"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/destinationAddressText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Calle 85 # 11-53, Bogotá"
            android:textColor="@color/hib_ink"
            android:textSize="13sp"
            android:textStyle="bold" />

        <!-- ITEMS -->
        <TextView
            android:id="@+id/itemsSummaryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="#FFF7F8"
            android:padding="6dp"
            android:text="Productos: 1x Skincare Serum, 1x Lip Gloss"
            android:textColor="#666666"
            android:textSize="12sp" />

        <!-- ACCEPT BUTTON -->
        <Button
            android:id="@+id/btnAcceptOrder"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:backgroundTint="@color/hib_pink"
            android:text="Aceptar Pedido"
            android:textColor="@color/white"
            android:textStyle="bold" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
