<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hib_page"
    android:fillViewport="true"
    android:clipToPadding="false"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="8dp">

        <!-- HEADER -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="18dp"
            android:background="@drawable/bg_admin_gradient"
            android:elevation="6dp"
            android:orientation="vertical"
            android:padding="22dp">

            <!-- TOP BAR -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Panel de Tienda"
                        android:textColor="#E9DFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/adminWelcomeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="¡Hola!"
                        android:textColor="@color/white"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Resumen general de HiBeauty"
                        android:textColor="#F4EEFF"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- SETTINGS -->

                <ImageView
                    android:id="@+id/btnLogoutAdmin"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_soft_circle"
                    android:backgroundTint="#40FFFFFF"
                    android:padding="13dp"
                    android:src="@drawable/ic_back"
                    android:rotation="180"
                    app:tint="@color/white" />
            </LinearLayout>

            <!-- STATS -->

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:columnCount="2">

                <!-- SALES -->

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="132dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_admin_card"
                    android:elevation="2dp"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_green_circle"
                        android:padding="8dp"
                        android:src="@drawable/ic_dollar"
                        android:tint="@color/white"
                        android:contentDescription="Ventas" />

                    <TextView
                        android:id="@+id/adminSales"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="$0"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="Ventas"
                        android:textColor="#EEE7FF"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/adminSalesGrowth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="+0%"
                        android:textColor="#B9FFD0"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- ORDERS -->

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="132dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_admin_card"
                    android:elevation="2dp"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_pink_circle"
                        android:padding="8dp"
                        android:src="@drawable/ic_nav_bag"
                        android:tint="@color/white"
                        android:contentDescription="Pedidos" />

                    <TextView
                        android:id="@+id/adminOrdersCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="0"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="Pedidos"
                        android:textColor="#EEE7FF"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/adminOrdersGrowth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="+0%"
                        android:textColor="#B9FFD0"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- USERS -->

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="132dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_admin_card"
                    android:elevation="2dp"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_purple_circle"
                        android:padding="8dp"
                        android:src="@drawable/ic_users"
                        android:tint="@color/white"
                        android:contentDescription="Clientes" />

                    <TextView
                        android:id="@+id/adminUsersCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="0"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="Clientes"
                        android:textColor="#EEE7FF"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/adminUsersGrowth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="+0%"
                        android:textColor="#B9FFD0"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- PRODUCTS -->

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="132dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_admin_card"
                    android:elevation="2dp"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_blue_circle"
                        android:padding="8dp"
                        android:src="@drawable/ic_package"
                        android:tint="@color/white"
                        android:contentDescription="Productos" />

                    <TextView
                        android:id="@+id/adminProductsCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="0"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="Productos"
                        android:textColor="#EEE7FF"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/adminProductsGrowth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="+0"
                        android:textColor="#B9FFD0"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </GridLayout>
        </LinearLayout>

        <!-- ALERT -->

        <LinearLayout
            android:id="@+id/alertStock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="24dp"
            android:background="@drawable/bg_alert_yellow"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_soft_circle"
                android:backgroundTint="#33FF9800"
                android:padding="8dp"
                android:src="@drawable/ic_warning"
                android:tint="#E65100"
                android:contentDescription="Alerta" />

            <TextView
                android:id="@+id/adminLowStockText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Stock bajo detectado"
                android:textColor="#6D4C41"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- QUICK ACTIONS -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="30dp"
            android:text="Acciones rápidas"
            android:textColor="@color/hib_ink"
            android:textSize="20sp"
            android:textStyle="bold" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:columnCount="2"
            android:paddingHorizontal="18dp">

            <!-- INVENTORY -->

            <LinearLayout
                android:id="@+id/btnInventory"
                android:layout_width="0dp"
                android:layout_height="104dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:background="@drawable/bg_card_white"
                android:elevation="2dp"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ic_search"
                    app:tint="@color/hib_ink" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Productos"
                    android:textColor="@color/hib_ink"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- ORDERS -->

            <LinearLayout
                android:id="@+id/btnOrders"
                android:layout_width="0dp"
                android:layout_height="104dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:background="@drawable/bg_card_white"
                android:elevation="2dp"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ic_nav_bag"
                    app:tint="@color/hib_ink" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Pedidos"
                    android:textColor="@color/hib_ink"
                    android:textStyle="bold" />
            </LinearLayout>
        </GridLayout>

        <!-- RECENT ORDERS -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pedidos recientes"
                android:textColor="@color/hib_ink"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnViewAllOrders"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ver todos"
                android:textColor="@color/hib_violet"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/containerRecentOrders"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical"
            android:paddingHorizontal="24dp" />

        <!-- TOP PRODUCTS -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="30dp"
            android:text="Productos más vendidos"
            android:textColor="@color/hib_ink"
            android:textSize="20sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/containerTopProducts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card_white"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="10dp" />

    </LinearLayout>

</ScrollView>