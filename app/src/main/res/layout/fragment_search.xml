<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hib_page"
    android:orientation="vertical">

    <!-- HEADER -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <ImageView
            android:id="@+id/btnBackSearch"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_soft_circle"
            android:padding="16dp"
            android:src="@drawable/ic_back" />

        <EditText
            android:id="@+id/searchInput"
            android:layout_width="0dp"
            android:layout_height="58dp"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:background="@drawable/bg_search"
            android:hint="Buscar productos ✨"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:textColor="@color/hib_ink"
            android:textColorHint="@color/hib_muted"
            android:textSize="18sp" />

    </LinearLayout>

    <!-- RESULTS -->

    <TextView
        android:id="@+id/searchResultsText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="28dp"
        android:text="Productos encontrados"
        android:textColor="@color/hib_ink"
        android:textSize="20sp"
        android:textStyle="bold" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/searchRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="16dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp" />

</LinearLayout>