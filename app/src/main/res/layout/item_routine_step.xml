<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/routineCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="18dp"
    android:background="@drawable/bg_card_large"
    android:clickable="true"
    android:focusable="true"
    android:elevation="4dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="20dp">

    <!-- STEP NUMBER -->

    <TextView
        android:id="@+id/stepIcon"
        android:layout_width="68dp"
        android:layout_height="68dp"
        android:background="@drawable/bg_circle_pink"
        android:gravity="center"
        android:text=""
        android:textColor="@color/hib_violet"
        android:textSize="28sp"
        android:textStyle="bold" />

    <!-- INFO -->

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/stepTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/hib_ink"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/stepDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text=""
            android:textColor="@color/hib_muted"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- STATUS -->

    <TextView
        android:id="@+id/stepStatus"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:background="@drawable/bg_soft_circle"
        android:gravity="center"
        android:text=""
        android:textSize="24sp" />

</LinearLayout>