<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hib_page"
    android:paddingStart="24dp"
    android:paddingTop="24dp"
    android:paddingEnd="24dp"
    android:paddingBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- BACK -->

        <ImageView
            android:id="@+id/btnBackPromos"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/bg_soft_circle"
            android:padding="12dp"
            android:src="@drawable/ic_back" />

        <!-- HEADER -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_admin_gradient"
            android:elevation="5dp"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Promociones"
                android:textColor="#FFFFFF"
                android:textSize="31sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Crea campañas suaves para destacar productos."
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- CARD -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_card_large"
            android:elevation="6dp"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Activar promoción"
                android:textColor="@color/hib_ink"
                android:textSize="24sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/promoTitle"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_search"
                android:hint="Título de la promoción"
                android:paddingStart="18dp"
                android:paddingEnd="18dp" />

            <EditText
                android:id="@+id/promoDiscount"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_search"
                android:hint="Descuento (%)"
                android:inputType="number"
                android:paddingStart="18dp"
                android:paddingEnd="18dp" />

            <TextView
                android:id="@+id/btnActivatePromo"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="22dp"
                android:background="@drawable/bg_button_pink"
                android:gravity="center"
                android:text="Activar promoción"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- INFO -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_soft_panel"
            android:elevation="5dp"
            android:padding="22dp"
            android:text="Sugerencia: usa títulos cortos como Glow Week, Rutina Express o Piel Radiante."
            android:textColor="@color/hib_ink"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

</ScrollView>