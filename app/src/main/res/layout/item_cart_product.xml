<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_card_large"
    android:elevation="5dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="16dp">

    <ImageView
        android:id="@+id/cartProductImage"
        android:layout_width="86dp"
        android:layout_height="86dp"
        android:background="@drawable/bg_product_image"
        android:contentDescription="Imagen del producto"
        android:scaleType="centerCrop" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/cartProductName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Producto"
            android:textColor="@color/hib_ink"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/cartProductPresentation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Presentación: 50ml"
            android:textColor="@color/hib_muted"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/cartProductQuantity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Cantidad: 1"
            android:textColor="@color/hib_muted"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/cartProductPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="$45.000"
            android:textColor="@color/hib_hot_pink"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/btnRemoveCartItem"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:gravity="center"
        android:text="×"
        android:textColor="@color/hib_pink"
        android:textSize="30sp"
        android:textStyle="bold" />
</LinearLayout>
