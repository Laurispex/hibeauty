<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hib_page"
    android:orientation="vertical">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <ImageView
            android:id="@+id/btnBackGuide"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_soft_circle"
            android:padding="16dp"
            android:src="@drawable/ic_back"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Regresar" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Guía Skincare "
            android:textColor="@color/hib_ink"
            android:textSize="26sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black" />

    </LinearLayout>

    <!-- CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="40dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tu rutina esencial, paso a paso"
                android:textColor="@color/hib_muted"
                android:textSize="16sp" />

            <!-- STEP 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_card_white"
                android:elevation="3dp"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🧴  Limpieza facial"
                    android:textColor="@color/hib_pink"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Usa un limpiador suave mañana y noche para eliminar grasa, suciedad e impurezas. Te recomendamos nuestro top de limpiadores en la categoría Maquillaje."
                    android:textColor="@color/hib_ink"
                    android:lineSpacingMultiplier="1.4"
                    android:textSize="15sp" />
            </LinearLayout>

            <!-- STEP 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card_white"
                android:elevation="3dp"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💧  Hidratación"
                    android:textColor="@color/hib_pink"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Aplica una crema hidratante adecuada para tu tipo de piel para mantenerla suave, nutrida y protegida durante todo el día."
                    android:textColor="@color/hib_ink"
                    android:lineSpacingMultiplier="1.4"
                    android:textSize="15sp" />
            </LinearLayout>

            <!-- STEP 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card_white"
                android:elevation="3dp"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="☀️  Protector solar"
                    android:textColor="@color/hib_pink"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Nunca olvides el protector solar, incluso en días nublados. Es el paso más importante para prevenir el envejecimiento prematuro."
                    android:textColor="@color/hib_ink"
                    android:lineSpacingMultiplier="1.4"
                    android:textSize="15sp" />
            </LinearLayout>

            <!-- TIP PRO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_banner_gradient"
                android:elevation="4dp"
                android:orientation="vertical"
                android:padding="22dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  Tip Pro"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Aplica el sérum sobre piel húmeda para maximizar su absorción. Espera 60 segundos antes de aplicar la crema hidratante."
                    android:textColor="#FFFFFF"
                    android:lineSpacingMultiplier="1.4"
                    android:textSize="15sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>