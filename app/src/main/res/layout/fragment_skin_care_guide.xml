<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hib_page"
    android:orientation="vertical">

    <!-- HEADER -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <ImageView
            android:id="@+id/btnBackGuide"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_soft_circle"
            android:padding="16dp"
            android:src="@drawable/ic_back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:text="Guía skincare ✨"
            android:textColor="@color/hib_ink"
            android:textSize="26sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black" />

    </LinearLayout>

    <!-- CONTENT -->

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Guía básica del cuidado de la piel ✨"
                android:textColor="@color/hib_ink"
                android:textSize="30sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="1. Limpieza facial"
                android:textColor="@color/hib_hot_pink"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Usa un limpiador suave mañana y noche para eliminar grasa, suciedad e impurezas. Para esto te recomendamos nuestro top de limpiadores en la categoria Maquillaje."
                android:textColor="@color/hib_ink"
                android:textSize="17sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:text="2. Hidratación"
                android:textColor="@color/hib_hot_pink"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Aplica una crema hidratante adecuada para mantener la piel suave y protegida."
                android:textColor="@color/hib_ink"
                android:textSize="17sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:text="3. Protector solar"
                android:textColor="@color/hib_hot_pink"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Nunca olvides el protector solar incluso en días nublados."
                android:textColor="@color/hib_ink"
                android:textSize="17sp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>