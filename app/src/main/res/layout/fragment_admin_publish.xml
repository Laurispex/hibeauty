<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hib_page"
    android:clipToPadding="false"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- BOTÓN ATRÁS -->
        <ImageView
            android:id="@+id/btnBackPublish"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_soft_circle"
            android:padding="12dp"
            android:src="@drawable/ic_back"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Regresar" />

        <!-- TITULO -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Añadir Producto"
            android:textColor="@color/hib_ink"
            android:textSize="32sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp"
            android:text="Completa la información para publicar en la tienda."
            android:textColor="@color/hib_muted"
            android:textSize="15sp" />

        <!-- CARD 1: INFORMACIÓN GENERAL -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_card_large"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Información General"
                android:textColor="@color/hib_ink"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/productName"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_search"
                android:hint="Nombre del producto (ej: Serum Niacinamida)"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@color/hib_ink"
                android:textColorHint="@color/hib_muted"
                android:textSize="15sp"
                android:inputType="textCapSentences" />

            <EditText
                android:id="@+id/productDescription"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_search"
                android:gravity="top"
                android:hint="Descripción comercial del producto..."
                android:padding="16dp"
                android:textColor="@color/hib_ink"
                android:textColorHint="@color/hib_muted"
                android:textSize="15sp"
                android:inputType="textMultiLine" />

            <EditText
                android:id="@+id/productBenefits"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_search"
                android:gravity="top"
                android:hint="Beneficios (separa con comas: Hidratación, Antiarrugas...)"
                android:padding="16dp"
                android:textColor="@color/hib_ink"
                android:textColorHint="@color/hib_muted"
                android:textSize="15sp"
                android:inputType="textMultiLine" />

            <EditText
                android:id="@+id/productHowToUse"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_search"
                android:gravity="top"
                android:hint="Modo de uso paso a paso..."
                android:padding="16dp"
                android:textColor="@color/hib_ink"
                android:textColorHint="@color/hib_muted"
                android:textSize="15sp"
                android:inputType="textMultiLine" />
        </LinearLayout>

        <!-- CARD 2: IMAGEN Y UPLOAD A CLOUDINARY -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_card_large"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fotografía del Producto"
                android:textColor="@color/hib_ink"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Selecciona una imagen de tu dispositivo. La subiremos a la nube de Cloudinary automáticamente:"
                android:textColor="@color/hib_muted"
                android:textSize="13sp" />

            <!-- PREST VIEW CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <ImageView
                    android:id="@+id/imagePublishPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_lotion_bottle"
                    android:background="@color/hib_cream" />
            </androidx.cardview.widget.CardView>

            <!-- LOADING INDICATOR -->
            <LinearLayout
                android:id="@+id/uploadProgressLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:visibility="gone">

                <ProgressBar
                    android:id="@+id/uploadProgress"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:indeterminateTint="@color/hib_pink" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Subiendo a Cloudinary..."
                    android:textColor="@color/hib_pink"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- SELECT BUTTON -->
            <TextView
                android:id="@+id/btnSelectImage"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_button_white"
                android:backgroundTint="@color/hib_cream"
                android:gravity="center"
                android:text="Elegir Foto de la Galería 📷"
                android:textColor="@color/hib_pink"
                android:textSize="15sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- CARD 3: CONFIGURACIÓN DESTACADA -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_card_large"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Etiquetas del Catálogo"
                android:textColor="@color/hib_ink"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical">

                <CheckBox
                    android:id="@+id/checkFeatured"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text=" Producto Bestseller"
                    android:drawableStart="@drawable/ic_star"
                    android:drawablePadding="12dp"
                    android:buttonTint="@color/hib_pink"
                    android:textColor="@color/hib_ink"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <CheckBox
                    android:id="@+id/checkNew"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="6dp"
                    android:text=" Nuevo Ingreso"
                    android:drawableStart="@drawable/ic_package"
                    android:drawablePadding="12dp"
                    android:buttonTint="@color/hib_pink"
                    android:textColor="@color/hib_ink"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <CheckBox
                    android:id="@+id/checkOffer"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="6dp"
                    android:text=" Oferta Especial"
                    android:drawableStart="@drawable/ic_dollar"
                    android:drawablePadding="12dp"
                    android:buttonTint="@color/hib_pink"
                    android:textColor="@color/hib_ink"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- CARD 4: CATEGORÍA -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_card_large"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Categoría Principal"
                android:textColor="@color/hib_ink"
                android:textSize="18sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/productCategoryGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/categorySkincare"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:checked="true"
                    android:text="Skincare (Cuidado facial)"
                    android:buttonTint="@color/hib_pink"
                    android:textColor="@color/hib_ink"
                    android:textSize="15sp" />

                <RadioButton
                    android:id="@+id/categoryMakeup"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="Maquillaje (Makeup)"
                    android:buttonTint="@color/hib_pink"
                    android:textColor="@color/hib_ink"
                    android:textSize="15sp" />

                <RadioButton
                    android:id="@+id/categoryFragrance"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="Fragancias (Aromas premium)"
                    android:buttonTint="@color/hib_pink"
                    android:textColor="@color/hib_ink"
                    android:textSize="15sp" />

                <RadioButton
                    android:id="@+id/categoryWellness"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="Bienestar (Wellness)"
                    android:buttonTint="@color/hib_pink"
                    android:textColor="@color/hib_ink"
                    android:textSize="15sp" />
            </RadioGroup>
        </LinearLayout>

        <!-- CARD 5: PRESENTACIONES Y DISPONIBILIDAD DINÁMICA -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_card_large"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Presentaciones e Inventario"
                android:textColor="@color/hib_ink"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"
                android:text="Crea presentaciones a la medida de tu producto (ej: '50ml', 'Tono Rojo', 'Pack x3'). Añade al menos una:"
                android:textColor="@color/hib_muted"
                android:textSize="13sp" />

            <!-- FORMULARIO RAPIDO AGREGAR -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <EditText
                    android:id="@+id/inputPresetName"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1.2"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_search"
                    android:hint="Nombre (ej: 50ml)"
                    android:inputType="textCapSentences"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textColor="@color/hib_ink"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/inputPresetPrice"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1.0"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_search"
                    android:hint="Precio COP"
                    android:inputType="number"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textColor="@color/hib_ink"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/inputPresetStock"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="0.8"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_search"
                    android:hint="Stock"
                    android:inputType="number"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textColor="@color/hib_ink"
                    android:textSize="13sp" />

                <!-- AGREGAR BOTÓN -->
                <ImageView
                    android:id="@+id/btnAddPresentation"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_soft_circle"
                    android:backgroundTint="@color/hib_cream"
                    android:padding="12dp"
                    android:src="@drawable/ic_flower"
                    android:clickable="true"
                    android:focusable="true"
                    app:tint="@color/hib_pink"
                    android:contentDescription="Añadir presentación" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EBEBEB"
                android:layout_marginBottom="14dp" />

            <!-- LISTA DE PRESENTACIONES AGREGADAS -->
            <LinearLayout
                android:id="@+id/containerPresentations"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>

        <!-- BOTÓN DE PUBLICAR -->
        <TextView
            android:id="@+id/btnPublishProduct"
            android:layout_width="match_parent"
            android:layout_height="62dp"
            android:layout_marginBottom="36dp"
            android:background="@drawable/bg_button_white"
            android:backgroundTint="@color/hib_pink"
            android:gravity="center"
            android:text="Publicar producto"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:elevation="4dp" />
    </LinearLayout>

</ScrollView>