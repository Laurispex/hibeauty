<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hib_page"
    android:paddingStart="24dp"
    android:paddingTop="24dp"
    android:paddingEnd="24dp"
    android:paddingBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- BACK -->

        <ImageView
            android:id="@+id/btnBackOrders"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/bg_soft_circle"
            android:padding="12dp"
            android:src="@drawable/ic_back" />

        <!-- HEADER -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_admin_gradient"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pedidos"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Actualiza el estado de cada compra en tiempo real."
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- INFO -->

        <TextView
            android:id="@+id/adminOrdersEmptyText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_card_large"
            android:elevation="5dp"
            android:padding="22dp"
            android:text="Cargando pedidos..."
            android:textColor="@color/hib_muted"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- LIST -->

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/adminOrdersRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:nestedScrollingEnabled="false" />
    </LinearLayout>

</ScrollView>