<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:background="@drawable/bg_card_white"
    android:elevation="5dp"
    android:orientation="horizontal"
    android:padding="16dp">

    <ImageView
        android:id="@+id/adminProductImage"
        android:layout_width="92dp"
        android:layout_height="112dp"
        android:background="@drawable/bg_product_image"
        android:contentDescription="Imagen del producto"
        android:scaleType="centerCrop" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/adminProductName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Producto"
            android:textColor="@color/hib_ink"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/adminProductCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_badge"
            android:paddingStart="12dp"
            android:paddingTop="5dp"
            android:paddingEnd="12dp"
            android:paddingBottom="5dp"
            android:text="Skincare"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/adminProductStock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="30ml: 10 uds"
            android:textColor="@color/hib_muted"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/adminProductStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Activo"
            android:textColor="@color/hib_admin"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
