<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_card_white"
    android:elevation="6dp"
    android:orientation="horizontal"
    android:padding="16dp">

    <!-- IMAGEN -->

    <ImageView
        android:id="@+id/adminProductImage"
        android:layout_width="92dp"
        android:layout_height="120dp"
        android:background="@drawable/bg_product_image"
        android:contentDescription="Imagen producto"
        android:scaleType="centerCrop" />

    <!-- INFO -->

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- NOMBRE -->

        <TextView
            android:id="@+id/adminProductName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/hib_ink"
            android:textSize="19sp"
            android:textStyle="bold" />

        <!-- CATEGORÍA -->

        <TextView
            android:id="@+id/adminProductCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_badge"
            android:paddingStart="12dp"
            android:paddingTop="5dp"
            android:paddingEnd="12dp"
            android:paddingBottom="5dp"
            android:text=""
            android:textColor="@color/hib_pink"
            android:textSize="12sp"
            android:textStyle="bold" />

        <!-- STOCK -->

        <TextView
            android:id="@+id/adminProductStock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text=""
            android:textColor="@color/hib_muted"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- STATUS -->

        <TextView
            android:id="@+id/adminProductStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_soft_panel"
            android:paddingStart="12dp"
            android:paddingTop="5dp"
            android:paddingEnd="12dp"
            android:paddingBottom="5dp"
            android:text=""
            android:textColor="@color/hib_admin"
            android:textSize="13sp"
            android:textStyle="bold" />

        <!-- BUTTONS -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <!-- EDITAR -->

            <TextView
                android:id="@+id/btnEditProduct"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_soft_panel"
                android:gravity="center"
                android:text="Editar"
                android:textColor="@color/hib_admin"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- ELIMINAR -->

            <TextView
                android:id="@+id/btnDeleteProduct"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_pink"
                android:gravity="center"
                android:text="Eliminar"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>