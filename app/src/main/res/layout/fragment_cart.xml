<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hib_page">

    <!-- CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="20dp"
        android:paddingTop="12dp"
        android:paddingEnd="20dp"
        android:paddingBottom="280dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:background="@drawable/bg_card_white"
                android:elevation="4dp"
                android:gravity="center"
                android:text="Mi Carrito"
                android:textColor="@color/hib_ink"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:drawableStart="@drawable/ic_nav_bag"
                android:drawablePadding="12dp"
                android:drawableTint="@color/hib_pink"
                android:paddingStart="24dp"
                android:paddingEnd="24dp" />

            <!-- ADD MORE -->
            <TextView
                android:id="@+id/btnAddMore"
                android:layout_width="match_parent"
                android:layout_height="62dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_status_track"
                android:elevation="2dp"
                android:gravity="center"
                android:text="+ Agregar más productos"
                android:textColor="@color/hib_hot_pink"
                android:textSize="17sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

            <!-- EMPTY -->
            <TextView
                android:id="@+id/cartEmptyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_card_white"
                android:elevation="3dp"
                android:padding="22dp"
                android:text="Cargando carrito..."
                android:textColor="@color/hib_muted"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- PRODUCTS -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/cartRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:nestedScrollingEnabled="false" />

            <!-- DISCOUNT -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_soft_panel"
                android:elevation="3dp"
                android:orientation="vertical"
                android:padding="22dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="¿Tienes un código de descuento?"
                    android:textColor="@color/hib_ink"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Aplica promociones y beneficios exclusivos"
                    android:textColor="@color/hib_muted"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="18dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="12dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_search"
                        android:gravity="center_vertical"
                        android:paddingStart="18dp"
                        android:text="Ingresa tu código"
                        android:textColor="@color/hib_muted"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="120dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_button_pink"
                        android:gravity="center"
                        android:text="Aplicar"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>
            </LinearLayout>

            <!-- DELIVERY -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_card_white"
                android:elevation="4dp"
                android:orientation="vertical"
                android:padding="22dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Opciones de entrega"
                    android:textColor="@color/hib_ink"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:drawableStart="@drawable/ic_package"
                    android:drawablePadding="10dp"
                    android:drawableTint="@color/hib_pink"
                    android:gravity="center_vertical" />

                <!-- STANDARD -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="76dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_status_track"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Entrega estándar"
                            android:textColor="@color/hib_ink"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="2-3 días hábiles"
                            android:textColor="@color/hib_muted"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$8.000"
                        android:textColor="@color/hib_hot_pink"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- EXPRESS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="76dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_search"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Entrega express"
                            android:textColor="@color/hib_ink"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="24 horas"
                            android:textColor="@color/hib_muted"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$15.000"
                        android:textColor="@color/hib_hot_pink"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- CHECKOUT PANEL -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_card_white"
        android:elevation="18dp"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="22dp"
        android:paddingEnd="24dp"
        android:paddingBottom="28dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Resumen de compra"
            android:textColor="@color/hib_ink"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:drawableStart="@drawable/ic_nav_sparkle"
            android:drawablePadding="10dp"
            android:drawableTint="@color/hib_pink"
            android:gravity="center_vertical" />

        <!-- SUBTOTAL -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Subtotal"
                android:textColor="@color/hib_muted"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/cartSubtotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$0"
                android:textColor="@color/hib_ink"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- SHIPPING -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Envío"
                android:textColor="@color/hib_muted"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/cartShipping"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$0"
                android:textColor="@color/hib_ink"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- DIVIDER -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="18dp"
            android:background="#F1D8EA" />

        <!-- TOTAL -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total"
                    android:textColor="@color/hib_ink"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Impuestos incluidos"
                    android:textColor="@color/hib_muted"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/cartTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$0"
                android:textColor="@color/hib_hot_pink"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black" />
        </LinearLayout>

        <!-- CHECKOUT -->
        <TextView
            android:id="@+id/btnCheckout"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_button_pink"
            android:elevation="4dp"
            android:gravity="center"
            android:text="Pedir Contraentrega"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="Pagas al recibir tu pedido en casa ✨"
            android:textColor="@color/hib_muted"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

</FrameLayout>