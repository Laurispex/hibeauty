<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hib_page"
    android:clipToPadding="false"
    android:paddingStart="22dp"
    android:paddingTop="18dp"
    android:paddingEnd="22dp"
    android:paddingBottom="34dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btnBackProfile"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_soft_circle"
                android:padding="16dp"
                android:src="@drawable/ic_back"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Regresar" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Mi Perfil"
                android:textColor="@color/hib_ink"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black" />

            <Space
                android:layout_width="56dp"
                android:layout_height="56dp" />
        </LinearLayout>

        <!-- LOGIN CONTAINER -->
        <LinearLayout
            android:id="@+id/loginContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¡Hola de nuevo!"
                android:textColor="@color/hib_ink"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Inicia sesión para ver tu perfil"
                android:textColor="@color/hib_muted"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/loginEmail"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_card_white"
                android:elevation="2dp"
                android:hint="Correo electrónico"
                android:inputType="textEmailAddress"
                android:paddingStart="20dp"
                android:paddingEnd="20dp" />

            <EditText
                android:id="@+id/loginPassword"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card_white"
                android:elevation="2dp"
                android:hint="Contraseña"
                android:inputType="textPassword"
                android:paddingStart="20dp"
                android:paddingEnd="20dp" />

            <TextView
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_button_white"
                android:backgroundTint="@color/hib_pink"
                android:elevation="4dp"
                android:gravity="center"
                android:text="Ingresar"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btnShowRegister"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:text="¿No tienes cuenta? Regístrate aquí"
                android:textColor="@color/hib_pink"
                android:textSize="15sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- REGISTER CONTAINER -->
        <LinearLayout
            android:id="@+id/registerContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Únete a HiBeauty"
                android:textColor="@color/hib_ink"
                android:textSize="24sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/registerName"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_card_white"
                android:elevation="2dp"
                android:hint="Nombre completo"
                android:inputType="textPersonName"
                android:paddingStart="20dp"
                android:paddingEnd="20dp" />

            <EditText
                android:id="@+id/registerEmail"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card_white"
                android:elevation="2dp"
                android:hint="Correo electrónico"
                android:inputType="textEmailAddress"
                android:paddingStart="20dp"
                android:paddingEnd="20dp" />

            <EditText
                android:id="@+id/registerPhone"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_search"
                android:hint="Número de celular"
                android:inputType="phone"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textColor="@color/hib_ink"
                android:textColorHint="@color/hib_muted" />

            <EditText
                android:id="@+id/registerIdentification"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_search"
                android:hint="Número de identificación"
                android:inputType="number"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textColor="@color/hib_ink"
                android:textColorHint="@color/hib_muted" />

            <EditText
                android:id="@+id/registerPassword"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card_white"
                android:elevation="2dp"
                android:hint="Contraseña"
                android:inputType="textPassword"
                android:paddingStart="20dp"
                android:paddingEnd="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Quiero registrarme como:"
                android:textColor="@color/hib_muted"
                android:textSize="14sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/registerRoleGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:checkedButton="@id/radioRoleUser"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/radioRoleUser"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Cliente"
                    android:textColor="@color/hib_ink"
                    android:buttonTint="@color/hib_pink"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <RadioButton
                    android:id="@+id/radioRoleDelivery"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Repartidor"
                    android:textColor="@color/hib_ink"
                    android:buttonTint="@color/hib_pink"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </RadioGroup>

            <LinearLayout
                android:id="@+id/deliveryFieldsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <EditText
                    android:id="@+id/registerVehicle"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_search"
                    android:hint="Vehículo (Ej: Moto, Bici, Carro)"
                    android:inputType="text"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:textColor="@color/hib_ink"
                    android:textColorHint="@color/hib_muted" />

                <EditText
                    android:id="@+id/registerPlate"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_search"
                    android:hint="Placa del vehículo"
                    android:inputType="textCapCharacters"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:textColor="@color/hib_ink"
                    android:textColorHint="@color/hib_muted" />
            </LinearLayout>

            <TextView
                android:id="@+id/btnRegister"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_button_white"
                android:backgroundTint="@color/hib_pink"
                android:elevation="4dp"
                android:gravity="center"
                android:text="Crear cuenta"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btnShowLogin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:text="¿Ya tienes cuenta? Inicia sesión"
                android:textColor="@color/hib_pink"
                android:textSize="15sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- USER PANEL (PROFILE) -->
        <LinearLayout
            android:id="@+id/userPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- PROFILE CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_promo"
                android:elevation="8dp"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- TOP -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="92dp"
                        android:layout_height="92dp"
                        android:background="@drawable/bg_button_white"
                        android:padding="22dp"
                        android:src="@drawable/ic_simple_person"
                        app:tint="@color/hib_pink"
                        android:contentDescription="Avatar del usuario" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="18dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/profileName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            tools:text="Valentina"
                            android:textColor="#FFFFFF"
                            android:textSize="28sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/profileEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            tools:text="correo@example.com"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <TextView
                            android:layout_width="140dp"
                            android:layout_height="38dp"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/bg_soft_panel"
                            android:gravity="center"
                            android:text="Beauty VIP"
                            android:textColor="@color/hib_pink"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- STATS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="92dp"
                    android:layout_marginTop="24dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/btnOrders"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_soft_panel"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:id="@+id/profileOrdersCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            tools:text="12"
                            android:textColor="@color/hib_pink"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pedidos"
                            android:textColor="@color/hib_ink"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnPoints"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_soft_panel"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:id="@+id/profilePoints"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            tools:text="450"
                            android:textColor="@color/hib_pink"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Puntos"
                            android:textColor="@color/hib_ink"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnCoupons"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_soft_panel"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:id="@+id/profileDiscounts"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/hib_pink"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Descuentos"
                            android:textColor="@color/hib_ink"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- NEXT LEVEL -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:background="@drawable/bg_card_white"
                android:elevation="5dp"
                android:orientation="horizontal"
                android:padding="22dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Próximo nivel Beauty Premium"
                        android:textColor="@color/hib_ink"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <ProgressBar
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="12dp"
                        android:layout_marginTop="12dp"
                        android:max="100"
                        android:progress="0"
                        android:progressTint="@color/hib_pink" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Completa pedidos para desbloquear"
                        android:textColor="@color/hib_muted"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="18dp"
                    android:layout_gravity="center_vertical"
                    android:src="@drawable/ic_crown"
                    app:tint="@color/hib_pink"
                    android:contentDescription="Recompensa de nivel" />
            </LinearLayout>

            <!-- ACCOUNT -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:text="Mi cuenta"
                android:textColor="@color/hib_muted"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- BUTTONS -->
            <TextView
                android:id="@+id/btnFavorites"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card_white"
                android:elevation="4dp"
                android:gravity="center_vertical"
                android:paddingStart="24dp"
                android:text="Favoritos"
                android:textColor="@color/hib_ink"
                android:textSize="17sp"
                android:textStyle="bold"
                android:drawableStart="@drawable/ic_nav_heart"
                android:drawablePadding="16dp"
                android:drawableTint="@color/hib_pink"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btnAddresses"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_card_white"
                android:elevation="4dp"
                android:gravity="center_vertical"
                android:paddingStart="24dp"
                android:text="Direcciones"
                android:textColor="@color/hib_ink"
                android:textSize="17sp"
                android:textStyle="bold"
                android:drawableStart="@drawable/ic_location_pin"
                android:drawablePadding="16dp"
                android:drawableTint="@color/hib_pink"
                android:clickable="true"
                android:focusable="true" />

            <!-- PREFERENCES -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:text="Preferencias"
                android:textColor="@color/hib_muted"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnNotifications"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card_white"
                android:elevation="4dp"
                android:gravity="center_vertical"
                android:paddingStart="24dp"
                android:text="Notificaciones"
                android:textColor="@color/hib_ink"
                android:textSize="17sp"
                android:textStyle="bold"
                android:drawableStart="@drawable/ic_nav_sparkle"
                android:drawablePadding="16dp"
                android:drawableTint="@color/hib_pink"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btnSettings"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_card_white"
                android:elevation="4dp"
                android:gravity="center_vertical"
                android:paddingStart="24dp"
                android:text="Configuración"
                android:textColor="@color/hib_ink"
                android:textSize="17sp"
                android:textStyle="bold"
                android:drawableStart="@drawable/ic_filter"
                android:drawablePadding="16dp"
                android:drawableTint="@color/hib_pink"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btnSupport"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_card_white"
                android:elevation="4dp"
                android:gravity="center_vertical"
                android:paddingStart="24dp"
                android:text="Ayuda y soporte"
                android:textColor="@color/hib_ink"
                android:textSize="17sp"
                android:textStyle="bold"
                android:drawableStart="@drawable/ic_warning"
                android:drawablePadding="16dp"
                android:drawableTint="@color/hib_pink"
                android:clickable="true"
                android:focusable="true" />

            <!-- LOGOUT -->
            <TextView
                android:id="@+id/btnLogoutUser"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginTop="30dp"
                android:layout_marginBottom="26dp"
                android:background="@drawable/bg_card_white"
                android:elevation="4dp"
                android:gravity="center"
                android:text="Cerrar sesión"
                android:textColor="@color/hib_hot_pink"
                android:textSize="18sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
