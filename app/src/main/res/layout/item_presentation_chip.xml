<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_search"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp">

    <!-- PRESENTATION NAME -->
    <TextView
        android:id="@+id/txtPresName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.2"
        android:textColor="@color/hib_ink"
        android:textSize="14sp"
        android:textStyle="bold" />

    <!-- PRESENTATION PRICE -->
    <TextView
        android:id="@+id/txtPresPrice"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.2"
        android:textColor="@color/hib_pink"
        android:textSize="14sp"
        android:textStyle="bold" />

    <!-- PRESENTATION STOCK -->
    <TextView
        android:id="@+id/txtPresStock"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.8"
        android:textColor="@color/hib_muted"
        android:textSize="13sp" />

    <!-- DELETE ACTION -->
    <ImageView
        android:id="@+id/btnDeletePres"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_soft_circle"
        android:padding="9dp"
        android:src="@drawable/ic_trash"
        android:clickable="true"
        android:focusable="true"
        app:tint="@color/hib_pink"
        android:contentDescription="Eliminar presentación" />
</LinearLayout>
