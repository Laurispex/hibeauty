<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hib_page"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="120dp">

        <!-- HEADER -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <ImageView
                android:id="@+id/btnBackDiscover"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_soft_circle"
                android:padding="15dp"
                android:src="@drawable/ic_back" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Descubre ✨"
                android:textColor="@color/hib_ink"
                android:textSize="24sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black" />

            <ImageView
                android:id="@+id/btnSearchDiscover"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_soft_circle"
                android:padding="15dp"
                android:src="@drawable/ic_search" />

        </LinearLayout>

        <!-- TENDENCIAS -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="34dp"
            android:text="📈 Tendencias"
            android:textColor="@color/hib_ink"
            android:textSize="21sp"
            android:textStyle="bold" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="24dp"
                android:paddingEnd="24dp">

                <!-- TREND 1 -->

                <LinearLayout
                    android:layout_width="230dp"
                    android:layout_height="96dp"
                    android:layout_marginEnd="14dp"
                    android:background="@drawable/bg_category_fragrance"
                    android:elevation="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌸"
                        android:textSize="30sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Glass Skin"
                            android:textColor="@color/hib_ink"
                            android:textSize="19sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="+24% tendencia"
                            android:textColor="@color/hib_muted"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

                <!-- TREND 2 -->

                <LinearLayout
                    android:layout_width="230dp"
                    android:layout_height="96dp"
                    android:layout_marginEnd="14dp"
                    android:background="@drawable/bg_banner_gradient"
                    android:elevation="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✨"
                        android:textSize="30sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Glow Natural"
                            android:textColor="@color/hib_ink"
                            android:textSize="19sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Top primavera"
                            android:textColor="@color/hib_muted"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </HorizontalScrollView>

        <!-- DESAFIOS -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="38dp"
            android:text="✨ Desafíos Beauty"
            android:textColor="@color/hib_ink"
            android:textSize="21sp"
            android:textStyle="bold" />

        <!-- CHALLENGE CARD -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="18dp"
            android:layout_marginEnd="24dp"
            android:background="@drawable/bg_card_large"
            android:elevation="4dp"
            android:orientation="horizontal"
            android:padding="18dp">

            <LinearLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_button_pink"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✨"
                    android:textSize="34sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="7 Días de Glow"
                    android:textColor="@color/hib_ink"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:maxLines="2"
                    android:text="Rutina matutina para piel radiante"
                    android:textColor="@color/hib_muted"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="👥 2.4K participantes"
                    android:textColor="@color/hib_muted"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <TextView
                android:id="@+id/btnJoinGlow"
                android:layout_width="92dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_button_pink"
                android:gravity="center"
                android:text="Unirse"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- TIPS -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="38dp"
            android:text="📖 Tips + Vlogs"
            android:textColor="@color/hib_ink"
            android:textSize="21sp"
            android:textStyle="bold" />

        <!-- VLOG CARD -->

        <!-- VLOG CARD -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="18dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="26dp"
            android:background="@drawable/bg_card_large"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- VIDEO COVER -->

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="190dp"
                android:background="@drawable/bg_banner_gradient">

                <!-- PLAY BUTTON -->

                <TextView
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_soft_circle"
                    android:elevation="5dp"
                    android:gravity="center"
                    android:text="▶"
                    android:textColor="@color/hib_ink"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <!-- LABEL -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|start"
                    android:layout_margin="14dp"
                    android:background="@drawable/bg_badge"
                    android:paddingStart="12dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="5dp"
                    android:text="VLOG"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />

            </FrameLayout>

            <!-- TITLE -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:maxLines="2"
                android:text="Morning Routine para Glass Skin ✨"
                android:textColor="@color/hib_ink"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black" />

            <!-- DESCRIPTION -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:maxLines="3"
                android:text="Aprende una rutina rápida para hidratar, iluminar y lograr una piel glow natural."
                android:textColor="@color/hib_muted"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- STATS -->

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💖 12.8K likes"
                    android:textColor="@color/hib_muted"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="18dp"
                    android:text="⏱ 5 min"
                    android:textColor="@color/hib_muted"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>