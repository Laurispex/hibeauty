<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/hib_page"
    android:fillViewport="true"
    android:clipToPadding="false"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:background="@drawable/bg_admin_gradient"
            android:elevation="6dp"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HiBeauty Delivery"
                        android:textColor="#E9DFFF"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/deliveryWelcomeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="¡Hola, Repartidor!"
                        android:textColor="@color/white"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- LOGOUT -->
                <ImageView
                    android:id="@+id/btnLogoutDelivery"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_soft_circle"
                    android:backgroundTint="#40FFFFFF"
                    android:padding="10dp"
                    android:src="@drawable/ic_logout"
                    app:tint="@color/white" />
            </LinearLayout>

            <!-- AVAILABILITY ROW -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_admin_card"
                android:backgroundTint="#20FFFFFF"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp">

                <TextView
                    android:id="@+id/textAvailabilityStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Estado: Conectado (Disponible)"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchAvailability"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    app:useMaterialThemeColors="true" />
            </LinearLayout>

            <!-- RIDER STATS -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:columnCount="2">

                <!-- TRIP COUNT -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_admin_card"
                    android:elevation="1dp"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Entregas exitosas"
                        android:textColor="#80FFFFFF"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/textCompletedDeliveries"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="0"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- EARNINGS -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_admin_card"
                    android:elevation="1dp"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ganancias"
                        android:textColor="#80FFFFFF"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/textTotalEarnings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="$0"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </GridLayout>
        </LinearLayout>

        <!-- ACTIVE DELIVERY CARD (HUD) -->
        <LinearLayout
            android:id="@+id/cardActiveDelivery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_admin_card"
            android:backgroundTint="#FFFFFF"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Pedido Activo en Curso"
                    android:textColor="@color/hib_hot_pink"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/activeOrderId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="#BT-0000"
                    android:textColor="@color/hib_ink"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="12dp"
                android:background="#FFE0E0" />

            <!-- STORE DETAIL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1. Recoger en Tienda:"
                android:textColor="@color/hib_ink"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="HiBeauty Sede Principal — Av. Carrera 15 # 82-24, Bogotá"
                android:textColor="#555555"
                android:textSize="13sp" />

            <!-- CLIENT DETAIL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="2. Entregar a Cliente:"
                android:textColor="@color/hib_ink"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/activeClientName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text=""
                android:textColor="@color/hib_ink"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/activeClientAddress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text=""
                android:textColor="@color/hib_muted"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/activeClientPhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text=""
                android:textColor="@color/hib_muted"
                android:textSize="13sp" />

            <!-- ITEMS -->
            <TextView
                android:id="@+id/activeOrderItemsSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@color/hib_surface"
                android:padding="10dp"
                android:text=""
                android:textColor="@color/hib_ink"
                android:textSize="12sp" />

            <!-- ACTIONS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnCallClient"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="Llamar"
                    app:icon="@android:drawable/stat_sys_phone_call"
                    app:strokeColor="@color/hib_pink" />

                <Button
                    android:id="@+id/btnUpdateDeliveryStatus"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="@color/hib_pink"
                    android:text="Marcar como En Camino"
                    android:textColor="@color/white" />
            </LinearLayout>
        </LinearLayout>

        <!-- NO PENDING DELIVERIES STATE -->
        <LinearLayout
            android:id="@+id/layoutEmptyDeliveries"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="40dp"
            android:visibility="visible">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="#FFE0E0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Buscando pedidos..."
                android:textColor="@color/hib_ink"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:text="En cuanto una tienda termine de preparar un pedido, aparecerá aquí al instante para que lo entregues."
                android:textColor="@color/hib_muted"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- AVAILABLE ORDERS SECTION -->
        <LinearLayout
            android:id="@+id/layoutAvailableDeliveries"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"
                android:text="Pedidos Disponibles en tu Zona"
                android:textColor="@color/hib_ink"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- LIST CONTAINER -->
            <LinearLayout
                android:id="@+id/containerAvailableOrders"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
